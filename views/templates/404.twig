{% extends 'layouts/base.twig' %}
{% block content %}
    <article class="error-404 wp-site-blocks has-global-padding is-layout-constrained">
        <h1>Page Not Found</h1>
        <p>Sorry, we couldn't find what you're looking for. It might have been removed, renamed, or did not exist in the first place.</p>
        <div class="wp-block-buttons">
            <div class="wp-block-button">
                <a class="wp-block-button__link wp-element-button" href="{{ site.url }}">Return to Homepage</a>
            </div>
        </div>
    </article>
{% endblock %}
