{% set slider = slider ?? {} %}
{% set slider_id = slider.id ?? function('uniqid', 'slider-') %}
{% set slider_class = slider.class ?? 'sc-content-slider splide' %}
{% set slider_config = function('wp_json_encode', slider.config ?? []) %}

{% if is_preview %}
    <div {{ block_wrapper_attributes(wrapper_attributes) }}>
        {{ inner_blocks(innerBlocksConfig) }}
    </div>
{% else %}
    <div
        id="{{ slider_id }}"
        class="{{ slider_class }}"
        data-sc-slider="{{ slider_config|default('[]')|e('html_attr') }}"
        aria-label="{{ slider.config.ariaLabel ?? 'Content slider' }}"
        data-gtm="Content Slider"
        role="region"
    >
        <div class="splide__track">
            <ul class="splide__list">
                {# Skip slides that render no meaningful content (e.g. an inner block whose
                   source post was deleted). The slide wrapper (Kadence column) always renders
                   its empty container divs, so test the rendered payload for text or media
                   rather than for an empty string. #}
                {% for slide in inner_blocks %}
                    {% set slide_html = render_block(slide) %}
                    {% if slide_html|striptags|trim is not empty
                          or slide_html matches '/<(img|svg|video|iframe|picture|canvas|audio)\\b/i' %}
                        <li class="splide__slide">
                            {{ slide_html }}
                        </li>
                    {% endif %}
                {% endfor %}
            </ul>
        </div>
    </div>
{% endif %}
